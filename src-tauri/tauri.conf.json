{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moss",
  "version": "0.4.1",
  "identifier": "app.getmoss.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Moss",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri: blob: https:; connect-src 'self' wss: ws:; font-src 'self' data: asset:; worker-src 'self' blob:; object-src 'none';"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/pdevera15/moss-updates/main/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1RUUyOTc5QTdBQUU0RjEKUldUeDVLcW5lU251WlhGVU81MHd2ZmJTb0pGT3RteXUwb2lMRUFuQUY3VjRJd3JnRldiUXAxUDEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
